###
# Qmini_lab docker dev workflow — general settings
###

# Prebuilt Isaac Lab base image that the Qmini_lab dev image is layered on.
# Isaac Sim 6.0 / xyzw quats / Newton — the 3.0 line the port targets.
ISAACLAB_BASE_IMAGE=nvcr.io/nvidia/isaac-lab:3.0.0-beta2-post1

# The Qmini_lab project path inside the container (also the bind-mount target for live edits).
DOCKER_ISAACLAB_EXTENSION_TEMPLATE_PATH=/workspace/Qmini_lab
