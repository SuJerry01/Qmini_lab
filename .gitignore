# used to configure VS Code settings
!.vscode

# Outputs
**/output/*
**/outputs/*
**/videos/*
**/wandb/*
**/.neptune/*
docker/artifacts/
*.tmp

# Doc Outputs
**/docs/_build/*
**/generated/*

# Isaac-Sim packman
_isaac_sim*
_repo
_build
.lastformat

# RL-Games
**/runs/*
**/logs/*
**/recordings/*

# Pre-Trained Checkpoints
/.pretrained_checkpoints/

# Teleop Recorded Dataset
/datasets/

# Tests
tests/

# Docker history
.isaac-lab-docker-history

# TacSL sensor
**/tactile_record/*
**/gelsight_r15_data/*

# No benchmarks output
/benchmarks/

# Ruff cache
**/.ruff_cache/

# Debug / diagnostic scripts (not part of the project — kept locally only)
debug/
_it.txt

# NvStreamer capture logs (root-owned viewer artifacts)
*.etli

# Local asset backups (pre-flatten originals live in q1-tamer/)
*.prefree_bak

# The verified flattened runtime asset IS tracked (exception to the template's no-USD rule):
# it's what the ContactSensor fix was validated against (docs/qmini_assets_debug.md).
!source/qmini_tasks/qmini_tasks/assets/q1/q1.usd

# stray root-level renders (canonical copies live under logs/)
/*.mp4

# local convenience copy of the golden reference policy (source of truth stays in ../RoboTamer4Qmini)
/models/*
!/models/golden_q2_rslrl.pt

# Internal / research files — kept locally, NOT published (excluded from the public repo).
# The runnable port (source/, scripts/rsl_rl, scripts/{list_envs,random_agent,zero_agent,convert_qmini_urdf,
# flatten_qmini_usd}, docker/, models/golden_q2_rslrl.pt, README) is self-contained without them.
/CLAUDE.md
/docs/
/experiment/
